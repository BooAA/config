# Configuration file for GNU Screen solely for its detaching capability

# Settings
altscreen on
defscrollback 100000
hardstatus off
ignorecase on
maptimeout 200
mousetrack on
startup_message off
truecolor on
vbell off
windowlist string "%4n %h%=%f"

# Key bindings
unbindall
escape ^\\\
bind d detach
bind : colon
